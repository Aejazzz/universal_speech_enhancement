# Normalize text to LF in the repo (avoids spurious CRLF-only diffs on Windows).
* text=auto eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.wav binary
*.flac binary
*.mp3 binary
*.pt binary
*.pth binary
*.ckpt binary
*.onnx binary
*.parquet binary
*.npz binary
*.npy binary
